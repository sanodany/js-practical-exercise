function arrayStats(array){
let sum1 = 0;
let average1;
let min1=0;
let max1=0;
for(i=0;i<array.length;i++){
    let value = array[i]
    sum1 += value
    min1 = array[0]
    max1 = array[0]
    if(min1>array[i]){
        min1=array[i]
    } else if(max1<array[i]){
        max1 = array[i]
    }
}
  average1 = sum1/array.length
const arrayObj={
    sum:sum1,
    average:parseFloat(average1.toFixed(2)),
    min: min1,
    max: max1
}
return arrayObj
}
console.log(arrayStats([1,2,3,4,5]))
