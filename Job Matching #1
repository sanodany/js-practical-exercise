
function match(candidate, job) {
  // is this job a valid match for the candidate?
  if(!candidate.minSalary || !job.maxSalary){
      throw "Missing information on salary"
  }
  candidate.minSalary *= 0.9
  if(candidate.minSalary <= job.maxSalary){
      return true
  } else {
      return false
  }
}
console.log(match({
  minSalary: 120000
},{
  maxSalary: 140000
}))
