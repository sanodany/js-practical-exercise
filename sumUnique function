function sumUnique(nums){
    const count = {}
    let sum = 0
    for(let i=0;i<nums.length;i++){
        count[nums[i]] = (count[nums[i]] || 0) +1
    }
    for(key in count){
        if(count[key]===1){
            sum += Number(key)
        }
    }
 return sum
}
